{
  "name": "oap-ops-hub",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:wuunu": "cross-env VITE_ENABLE_WUUNU=true vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 0.0.0.0 --port 4174",
    "test:e2e": "npx -y @playwright/test test -c playwright.config.ts",
    "prepare-c4": "node ./scripts/prepare_c4_assets.mjs",
    "prepare-content": "node ./scripts/build_content_index.mjs",
    "check-agents": "node ./scripts/check_agents_manifest.mjs",
    "check": "npm run prepare-c4 && npm run prepare-content && npm run check-agents && npm run build"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@mui/icons-material": "^6.4.0",
    "@mui/material": "^6.4.0",
    "@sentry/react": "^10.40.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.1.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@sentry/vite-plugin": "^2.23.1",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "cross-env": "^7.0.3",
    "typescript": "^5.7.3",
    "vite": "^6.1.0"
  }
}
