{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pervoe-slovo.local/schemas/oap/agents-card.schema.json",
  "title": "OAP Agents Manifest",
  "description": "Contract for Operational Agent Panel (ОАП) card data.",
  "type": "object",
  "additionalProperties": false,
  "required": ["updatedAt", "source", "sourceVersion", "agents"],
  "properties": {
    "updatedAt": { "$ref": "#/$defs/nonEmptyString" },
    "source": { "$ref": "#/$defs/nonEmptyString" },
    "sourceVersion": { "$ref": "#/$defs/nonEmptyString" },
    "agents": {
      "type": "array",
      "items": { "$ref": "#/$defs/agent" }
    }
  },
  "$defs": {
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "stringArray": {
      "type": "array",
      "items": { "$ref": "#/$defs/nonEmptyString" }
    },
    "urlString": {
      "type": "string",
      "format": "uri",
      "minLength": 1
    },
    "capabilityDecisionGuidance": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "purpose": { "type": ["string", "null"] },
        "useWhen": { "type": ["string", "null"] },
        "avoidWhen": { "type": ["string", "null"] },
        "requiredContext": { "$ref": "#/$defs/stringArray" },
        "expectedOutput": { "type": ["string", "null"] },
        "failureModes": { "$ref": "#/$defs/stringArray" },
        "fallbackTo": { "$ref": "#/$defs/stringArray" },
        "examples": { "$ref": "#/$defs/stringArray" }
      }
    },
    "capabilityQualitySignals": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "reviewStatus": {
          "type": ["string", "null"],
          "enum": ["draft", "approved", "stale", null]
        },
        "lastReviewedAt": { "type": ["string", "null"] },
        "descriptionCompletenessScore": { "type": ["number", "null"] },
        "verifyPassAfterUseRate": { "type": ["number", "null"] },
        "fallbackAfterUseRate": { "type": ["number", "null"] },
        "improvementHint": { "type": ["string", "null"] },
        "recommendation": {
          "type": ["string", "null"],
          "enum": ["rewrite_current", "trial_alternative", "keep_current", "replace_after_trial", null]
        }
      }
    },
    "skillSourceRegistryEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "url", "trust", "kind", "description", "usagePolicy"],
      "properties": {
        "id": { "$ref": "#/$defs/nonEmptyString" },
        "title": { "$ref": "#/$defs/nonEmptyString" },
        "url": { "$ref": "#/$defs/urlString" },
        "trust": {
          "type": "string",
          "enum": ["official", "curated", "rejected", "discovery_only"]
        },
        "kind": {
          "type": "string",
          "enum": ["catalog_index", "official_docs", "official_repo", "curated_repo"]
        },
        "description": { "$ref": "#/$defs/nonEmptyString" },
        "usagePolicy": { "$ref": "#/$defs/nonEmptyString" }
      }
    },
    "externalSkillTrialMetrics": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "taskSuccessRate": { "type": ["number", "null"] },
        "verificationPassRate": { "type": ["number", "null"] },
        "timeToSolutionDeltaPct": { "type": ["number", "null"] },
        "tokenCostDeltaPct": { "type": ["number", "null"] },
        "fallbackRate": { "type": ["number", "null"] },
        "humanCorrectionRate": { "type": ["number", "null"] }
      }
    },
    "externalSkillCandidate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "sourceId",
        "sourceTitle",
        "trust",
        "summary",
        "targetSkills",
        "decisionGuidance",
        "qualitySignals",
        "trialStatus",
        "promotionStatus",
        "recommendation"
      ],
      "properties": {
        "id": { "$ref": "#/$defs/nonEmptyString" },
        "name": { "$ref": "#/$defs/nonEmptyString" },
        "sourceId": { "$ref": "#/$defs/nonEmptyString" },
        "sourceTitle": { "$ref": "#/$defs/nonEmptyString" },
        "sourceUrl": { "type": ["string", "null"] },
        "trust": {
          "type": "string",
          "enum": ["official", "curated", "rejected", "discovery_only"]
        },
        "summary": { "$ref": "#/$defs/nonEmptyString" },
        "targetSkills": { "$ref": "#/$defs/stringArray" },
        "expectedEffect": { "type": ["string", "null"] },
        "decisionGuidance": { "$ref": "#/$defs/capabilityDecisionGuidance" },
        "qualitySignals": { "$ref": "#/$defs/capabilityQualitySignals" },
        "trialStatus": {
          "type": "string",
          "enum": ["not_started", "scheduled", "running", "passed", "failed"]
        },
        "promotionStatus": {
          "type": "string",
          "enum": ["human_review_required", "approved", "watchlist", "rejected"]
        },
        "recommendation": {
          "type": "string",
          "enum": ["rewrite_current", "trial_alternative", "keep_current", "replace_after_trial"]
        },
        "recommendationReason": { "type": ["string", "null"] },
        "trialMetrics": {
          "anyOf": [
            { "$ref": "#/$defs/externalSkillTrialMetrics" },
            { "type": "null" }
          ]
        }
      }
    },
    "taskCounters": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "queued",
        "running",
        "retrying",
        "waiting_review",
        "blocked",
        "waiting_external",
        "overdue",
        "in_work",
        "on_control"
      ],
      "properties": {
        "queued": { "type": "number" },
        "running": { "type": "number" },
        "retrying": { "type": "number" },
        "waiting_review": { "type": "number" },
        "blocked": { "type": "number" },
        "waiting_external": { "type": "number" },
        "overdue": { "type": "number" },
        "in_work": { "type": "number" },
        "on_control": { "type": "number" }
      }
    },
    "repository": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "url", "branch"],
      "properties": {
        "name": { "$ref": "#/$defs/nonEmptyString" },
        "url": { "$ref": "#/$defs/urlString" },
        "branch": { "type": ["string", "null"] }
      }
    },
    "mcpServer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "status"],
      "properties": {
        "name": { "$ref": "#/$defs/nonEmptyString" },
        "status": {
          "type": "string",
          "enum": ["online", "degraded", "offline"]
        }
      }
    },
    "usedMcp": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "status", "note", "impactInNumbers", "practicalTasks"],
      "properties": {
        "name": { "$ref": "#/$defs/nonEmptyString" },
        "status": {
          "type": "string",
          "enum": ["active", "reauth_required", "degraded", "offline"]
        },
        "note": { "$ref": "#/$defs/nonEmptyString" },
        "impactInNumbers": { "$ref": "#/$defs/nonEmptyString" },
        "practicalTasks": { "$ref": "#/$defs/stringArray" },
        "lastUsedAt": { "type": ["string", "null"] },
        "decisionGuidance": {
          "anyOf": [
            { "$ref": "#/$defs/capabilityDecisionGuidance" },
            { "type": "null" }
          ]
        },
        "qualitySignals": {
          "anyOf": [
            { "$ref": "#/$defs/capabilityQualitySignals" },
            { "type": "null" }
          ]
        }
      }
    },
    "availableMcp": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "description",
        "whenToUse",
        "expectedEffect",
        "basis",
        "practicalTasks",
        "link",
        "installComplexity"
      ],
      "properties": {
        "name": { "$ref": "#/$defs/nonEmptyString" },
        "whyUseful": { "type": ["string", "null"] },
        "description": { "$ref": "#/$defs/nonEmptyString" },
        "whenToUse": { "$ref": "#/$defs/nonEmptyString" },
        "expectedEffect": { "$ref": "#/$defs/nonEmptyString" },
        "basis": { "$ref": "#/$defs/nonEmptyString" },
        "practicalTasks": { "$ref": "#/$defs/stringArray" },
        "link": { "$ref": "#/$defs/urlString" },
        "installComplexity": { "$ref": "#/$defs/nonEmptyString" },
        "decisionGuidance": {
          "anyOf": [
            { "$ref": "#/$defs/capabilityDecisionGuidance" },
            { "type": "null" }
          ]
        },
        "qualitySignals": {
          "anyOf": [
            { "$ref": "#/$defs/capabilityQualitySignals" },
            { "type": "null" }
          ]
        }
      }
    },
    "usedSkill": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "usage", "fullText", "practicalTasks"],
      "properties": {
        "name": { "$ref": "#/$defs/nonEmptyString" },
        "usage": { "$ref": "#/$defs/nonEmptyString" },
        "fullText": { "$ref": "#/$defs/nonEmptyString" },
        "practicalTasks": { "$ref": "#/$defs/stringArray" },
        "lastUsedAt": { "type": ["string", "null"] },
        "skillFilePath": { "type": ["string", "null"] },
        "skillFileText": { "type": ["string", "null"] },
        "skillFileLoaded": { "type": ["boolean", "null"] },
        "decisionGuidance": {
          "anyOf": [
            { "$ref": "#/$defs/capabilityDecisionGuidance" },
            { "type": "null" }
          ]
        },
        "qualitySignals": {
          "anyOf": [
            { "$ref": "#/$defs/capabilityQualitySignals" },
            { "type": "null" }
          ]
        }
      }
    },
    "availableSkill": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "benefit",
        "recommendationBasis",
        "expectedEffect",
        "fullText",
        "practicalTasks",
        "link"
      ],
      "properties": {
        "name": { "$ref": "#/$defs/nonEmptyString" },
        "benefit": { "$ref": "#/$defs/nonEmptyString" },
        "recommendationBasis": { "$ref": "#/$defs/nonEmptyString" },
        "expectedEffect": { "$ref": "#/$defs/nonEmptyString" },
        "fullText": { "$ref": "#/$defs/nonEmptyString" },
        "practicalTasks": { "$ref": "#/$defs/stringArray" },
        "link": { "$ref": "#/$defs/urlString" },
        "decisionGuidance": {
          "anyOf": [
            { "$ref": "#/$defs/capabilityDecisionGuidance" },
            { "type": "null" }
          ]
        },
        "qualitySignals": {
          "anyOf": [
            { "$ref": "#/$defs/capabilityQualitySignals" },
            { "type": "null" }
          ]
        }
      }
    },
    "usedTool": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "usage", "fullText", "source", "practicalTasks"],
      "properties": {
        "name": { "$ref": "#/$defs/nonEmptyString" },
        "usage": { "$ref": "#/$defs/nonEmptyString" },
        "fullText": { "$ref": "#/$defs/nonEmptyString" },
        "source": { "$ref": "#/$defs/nonEmptyString" },
        "practicalTasks": { "$ref": "#/$defs/stringArray" },
        "lastUsedAt": { "type": ["string", "null"] },
        "decisionGuidance": {
          "anyOf": [
            { "$ref": "#/$defs/capabilityDecisionGuidance" },
            { "type": "null" }
          ]
        },
        "qualitySignals": {
          "anyOf": [
            { "$ref": "#/$defs/capabilityQualitySignals" },
            { "type": "null" }
          ]
        }
      }
    },
    "availableTool": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "benefit",
        "recommendationBasis",
        "expectedEffect",
        "fullText",
        "source",
        "practicalTasks"
      ],
      "properties": {
        "name": { "$ref": "#/$defs/nonEmptyString" },
        "benefit": { "$ref": "#/$defs/nonEmptyString" },
        "recommendationBasis": { "$ref": "#/$defs/nonEmptyString" },
        "expectedEffect": { "$ref": "#/$defs/nonEmptyString" },
        "fullText": { "$ref": "#/$defs/nonEmptyString" },
        "source": { "$ref": "#/$defs/nonEmptyString" },
        "practicalTasks": { "$ref": "#/$defs/stringArray" },
        "decisionGuidance": {
          "anyOf": [
            { "$ref": "#/$defs/capabilityDecisionGuidance" },
            { "type": "null" }
          ]
        },
        "qualitySignals": {
          "anyOf": [
            { "$ref": "#/$defs/capabilityQualitySignals" },
            { "type": "null" }
          ]
        }
      }
    },
    "capabilityContract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mission", "entryCriteria", "doneCondition", "outputSchema"],
      "properties": {
        "mission": { "$ref": "#/$defs/nonEmptyString" },
        "entryCriteria": { "$ref": "#/$defs/stringArray" },
        "doneCondition": { "$ref": "#/$defs/nonEmptyString" },
        "outputSchema": { "$ref": "#/$defs/nonEmptyString" },
        "useWhen": { "$ref": "#/$defs/stringArray" },
        "avoidWhen": { "$ref": "#/$defs/stringArray" },
        "requiredContext": { "$ref": "#/$defs/stringArray" },
        "expectedOutput": { "$ref": "#/$defs/nonEmptyString" },
        "failureModes": { "$ref": "#/$defs/stringArray" },
        "fallbackTo": { "$ref": "#/$defs/stringArray" },
        "examples": { "$ref": "#/$defs/stringArray" }
      }
    },
    "contextRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "filePath"],
      "properties": {
        "title": { "$ref": "#/$defs/nonEmptyString" },
        "filePath": { "$ref": "#/$defs/nonEmptyString" },
        "pathHint": { "type": ["string", "null"] },
        "sourceUrl": { "type": ["string", "null"] }
      }
    },
    "taskEvent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "completedAt", "reviewErrors"],
      "properties": {
        "id": { "$ref": "#/$defs/nonEmptyString" },
        "title": { "$ref": "#/$defs/nonEmptyString" },
        "completedAt": { "$ref": "#/$defs/nonEmptyString" },
        "reviewErrors": { "type": "number" }
      }
    },
    "taskContextToTask": {
      "type": "object",
      "additionalProperties": false,
      "required": ["summary"],
      "properties": {
        "summary": { "$ref": "#/$defs/nonEmptyString" },
        "why_now": { "type": ["string", "null"] },
        "execution_notes": {
          "type": "array",
          "items": { "$ref": "#/$defs/nonEmptyString" }
        },
        "source_snapshot": { "type": ["object", "null"] }
      }
    },
    "analystRecommendation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["text"],
      "properties": {
        "id": { "$ref": "#/$defs/nonEmptyString" },
        "text": { "$ref": "#/$defs/nonEmptyString" },
        "linkedImprovementId": { "type": ["string", "null"] },
        "contextToTask": {
          "anyOf": [
            { "$ref": "#/$defs/taskContextToTask" },
            { "type": "null" }
          ]
        }
      }
    },
    "improvement": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "title",
        "problem",
        "solution",
        "effect",
        "priority",
        "ownerSection",
        "detectionBasis",
        "promptPath",
        "promptTitle",
        "promptMarkdown",
        "promptSourceUrl",
        "targetMetric",
        "baselineWindow",
        "expectedDelta",
        "validationDate",
        "ice"
      ],
      "properties": {
        "id": { "$ref": "#/$defs/nonEmptyString" },
        "title": { "$ref": "#/$defs/nonEmptyString" },
        "problem": { "$ref": "#/$defs/nonEmptyString" },
        "solution": { "$ref": "#/$defs/nonEmptyString" },
        "effect": { "$ref": "#/$defs/nonEmptyString" },
        "priority": { "$ref": "#/$defs/nonEmptyString" },
        "section": { "type": ["string", "null"] },
        "ownerSection": { "$ref": "#/$defs/nonEmptyString" },
        "detectionBasis": { "$ref": "#/$defs/nonEmptyString" },
        "promptPath": { "$ref": "#/$defs/nonEmptyString" },
        "promptTitle": { "$ref": "#/$defs/nonEmptyString" },
        "promptMarkdown": { "$ref": "#/$defs/nonEmptyString" },
        "promptSourceUrl": { "$ref": "#/$defs/nonEmptyString" },
        "targetMetric": { "$ref": "#/$defs/nonEmptyString" },
        "baselineWindow": { "$ref": "#/$defs/nonEmptyString" },
        "expectedDelta": { "$ref": "#/$defs/nonEmptyString" },
        "validationDate": { "$ref": "#/$defs/nonEmptyString" },
        "ice": {
          "type": "object",
          "additionalProperties": false,
          "required": ["impact", "confidence", "ease"],
          "properties": {
            "impact": { "type": "number" },
            "confidence": { "type": "number" },
            "ease": { "type": "number" }
          }
        }
      }
    },
    "operatingPlanSourcePolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "whitelist", "updateRule", "validationCriteria"],
      "properties": {
        "mode": { "$ref": "#/$defs/nonEmptyString" },
        "whitelist": {
          "type": "array",
          "items": { "$ref": "#/$defs/nonEmptyString" }
        },
        "updateRule": { "$ref": "#/$defs/nonEmptyString" },
        "validationCriteria": {
          "type": "array",
          "items": { "$ref": "#/$defs/nonEmptyString" }
        }
      }
    },
    "operatingPlanNotificationPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "criticalCases", "digestFields"],
      "properties": {
        "mode": { "$ref": "#/$defs/nonEmptyString" },
        "criticalCases": {
          "type": "array",
          "items": { "$ref": "#/$defs/nonEmptyString" }
        },
        "digestFields": {
          "type": "array",
          "items": { "$ref": "#/$defs/nonEmptyString" }
        }
      }
    },
    "operatingPlanMetricsCatalog": {
      "type": "object",
      "additionalProperties": false,
      "required": ["agents", "analyst"],
      "properties": {
        "agents": {
          "type": "array",
          "items": { "$ref": "#/$defs/nonEmptyString" }
        },
        "analyst": {
          "type": "array",
          "items": { "$ref": "#/$defs/nonEmptyString" }
        }
      }
    },
    "operatingPlan": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mission",
        "dailyLoop",
        "sourcePolicy",
        "notificationPolicy",
        "improvementLifecycle",
        "metricsCatalog",
        "decisionRules"
      ],
      "properties": {
        "mission": { "$ref": "#/$defs/nonEmptyString" },
        "dailyLoop": {
          "type": "array",
          "items": { "$ref": "#/$defs/nonEmptyString" }
        },
        "sourcePolicy": { "$ref": "#/$defs/operatingPlanSourcePolicy" },
        "notificationPolicy": { "$ref": "#/$defs/operatingPlanNotificationPolicy" },
        "improvementLifecycle": {
          "type": "array",
          "items": { "$ref": "#/$defs/nonEmptyString" }
        },
        "metricsCatalog": { "$ref": "#/$defs/operatingPlanMetricsCatalog" },
        "decisionRules": {
          "type": "array",
          "items": { "$ref": "#/$defs/nonEmptyString" }
        }
      }
    },
    "workflowPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "planDefault",
        "replanOnDeviation",
        "verifyBeforeDone",
        "selfImprovementLoop",
        "autonomousBugfix"
      ],
      "properties": {
        "planDefault": { "type": "boolean" },
        "replanOnDeviation": { "type": "boolean" },
        "verifyBeforeDone": { "type": "boolean" },
        "selfImprovementLoop": { "type": "boolean" },
        "autonomousBugfix": { "type": "boolean" }
      }
    },
    "workflowBackbone": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "version",
        "commonCoreSteps",
        "roleWindow",
        "stepExecutionPolicy",
        "supportsDynamicInstances"
      ],
      "properties": {
        "version": {
          "type": "string",
          "enum": ["universal_backbone_v1"]
        },
        "commonCoreSteps": {
          "type": "array",
          "items": { "$ref": "#/$defs/nonEmptyString" }
        },
        "roleWindow": {
          "type": "object",
          "additionalProperties": false,
          "required": ["entryStep", "exitStep", "purpose", "internalSteps"],
          "properties": {
            "entryStep": { "$ref": "#/$defs/nonEmptyString" },
            "exitStep": { "$ref": "#/$defs/nonEmptyString" },
            "purpose": { "$ref": "#/$defs/nonEmptyString" },
            "internalSteps": {
              "type": "array",
              "items": { "$ref": "#/$defs/nonEmptyString" }
            }
          }
        },
        "stepExecutionPolicy": {
          "type": "object",
          "additionalProperties": false,
          "required": ["skippedStepsAllowed", "skippedStepStatus"],
          "properties": {
            "skippedStepsAllowed": { "type": "boolean" },
            "skippedStepStatus": {
              "type": "string",
              "enum": ["skipped"]
            }
          }
        },
        "supportsDynamicInstances": { "type": "boolean" }
      }
    },
    "capabilityOptimization": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "enabled",
        "refreshMode",
        "sourcePolicy",
        "trialMode",
        "promotionMode",
        "minShadowSampleSize",
        "staleAfterHours"
      ],
      "properties": {
        "enabled": { "type": "boolean" },
        "refreshMode": {
          "type": "string",
          "enum": ["on_run"]
        },
        "sourcePolicy": {
          "type": "string",
          "enum": ["official_first"]
        },
        "trialMode": {
          "type": "string",
          "enum": ["shadow"]
        },
        "promotionMode": {
          "type": "string",
          "enum": ["human_approve"]
        },
        "minShadowSampleSize": { "type": "number" },
        "staleAfterHours": { "type": "number" }
      }
    },
    "learningArtifacts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["todoPath", "lessonsPath", "lastLessonAt"],
      "properties": {
        "todoPath": { "$ref": "#/$defs/nonEmptyString" },
        "lessonsPath": { "$ref": "#/$defs/nonEmptyString" },
        "lastLessonAt": { "type": ["string", "null"] }
      }
    },
    "doneGatePolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "requiredChecks", "fallbackStatus"],
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["soft_warning", "strict"]
        },
        "requiredChecks": {
          "type": "array",
          "items": { "$ref": "#/$defs/nonEmptyString" }
        },
        "fallbackStatus": {
          "type": "string",
          "enum": ["backlog", "ready", "in_progress", "ab_test", "in_review", "done"]
        }
      }
    },
    "capabilitySnapshotTrial": {
      "type": "object",
      "additionalProperties": false,
      "required": ["trialId", "candidateId", "candidateName", "sourceTitle", "sourceTrust", "representativeTasks", "eligible", "blockReasons"],
      "properties": {
        "trialId": { "$ref": "#/$defs/nonEmptyString" },
        "candidateId": { "$ref": "#/$defs/nonEmptyString" },
        "candidateName": { "$ref": "#/$defs/nonEmptyString" },
        "sourceTitle": { "$ref": "#/$defs/nonEmptyString" },
        "sourceUrl": { "type": ["string", "null"] },
        "sourceTrust": { "$ref": "#/$defs/nonEmptyString" },
        "baselineSkillName": { "type": ["string", "null"] },
