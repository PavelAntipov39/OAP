# ОАП — Operations & Agents Platform
# Скопируй в .env.local и заполни реальными значениями (никогда не коммить .env.local)

# Supabase (shared с Библией на Фазе 1)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Telegram digest
ANALYST_TELEGRAM_BOT_TOKEN=
ANALYST_TELEGRAM_CHAT_ID=

# Candidate intake / analyst-cycle
# Required for scripts/candidate_cycle_runner.py and daily Codex automation
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Optional: if TELEGRAM_BOT_TOKEN is not available locally, use n8n relay webhook
CANDIDATE_REPLY_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=

# WUUNU (локально, только для dev)
VITE_ENABLE_WUUNU=false
VITE_WUUNU_WS=http://127.0.0.1:62704/?token=

# Sentry (опционально)
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
VITE_APP_RELEASE=
